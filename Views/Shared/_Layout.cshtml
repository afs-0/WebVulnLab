<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web Vulnerability Lab</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="bg-dark text-white p-3">
        <h4>🛡️ Web Vulnerability Lab</h4>
    </header>

    <div class="container-fluid">
        <div class="row" style="min-height: 90vh;">
            <!-- SOL MENÜ SIDEBAR -->
            <nav class="col-md-2 bg-light p-3 border-end">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link text-dark fw-bold" href="/">Ana Sayfa</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="/xss">Cross-Site Scripting (XSS)</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">Broken Access Control</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">Security Misconfiguration</a>
                    </li>
                </ul>
            </nav>

            <!-- ANA İÇERİK ALANI -->
            <main class="col-md-10 p-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>