@{ ViewData["Title"] = "Güvenli Reflected XSS"; }

<h3 class="text-primary">Reflected XSS - Güvenli</h3>
<p class="text-muted">Burada standart <code class="text-primary">@@</code> operatörü kullanıldığı için ASP.NET veriyi otomatik olarak encode eder (zararsız metne çevirir).</p>
<hr />

<form action="/Xss/ReflectedSecure" method="get" class="mb-4">
    <div class="input-group w-50">
        <input type="text" name="searchKeyword" class="form-control" placeholder="Sitede ara..." />
        <button type="submit" class="btn btn-primary">Ara</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(ViewBag.Keyword))
{
    <div class="alert alert-primary">
        <!-- KORUMA BURADA -->
        Aranan Kelime: <strong>@ViewBag.Keyword</strong> 
    </div>
}

<div class="mt-4 p-3 bg-light border">
    <strong>Test Payload:</strong><br> 
    <code>&lt;script&gt;alert('XSS Çalıştı!')&lt;/script&gt;</code>
</div>