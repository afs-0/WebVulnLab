@model List<string>
@{ ViewData["Title"] = "Güvenli Stored XSS"; }

<h3 class="text-primary">Stored XSS - Güvenli</h3>
<p class="text-muted">Burada standart <code class="text-primary">@@</code> operatörü kullanıldığı için ASP.NET veriyi otomatik olarak encode eder.</p>
<hr />

<form action="/Xss/StoredSecure" method="post" class="mb-4">
    <textarea name="newComment" class="form-control w-50 mb-2" rows="2" placeholder="Yorum ekle..."></textarea>
    <button type="submit" class="btn btn-primary">Yorum Ekle</button>
</form>

<ul class="list-group w-50">
    @foreach (var comment in Model)
    {
        <!-- KORUMA BURADA -->
        <li class="list-group-item">@comment</li>
    }
</ul>

<div class="mt-4 p-3 bg-light border">
    <strong>Test Payload:</strong><br>
    <code>&lt;img src="x" onerror="alert('Kalıcı XSS!')"&gt;</code>
</div>