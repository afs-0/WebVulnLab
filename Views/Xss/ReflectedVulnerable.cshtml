@{ ViewData["Title"] = "Zafiyetli Reflected XSS"; }

<h3 class="text-danger">Reflected XSS - Zafiyetli</h3>
<p class="text-muted">Burada <code class="text-danger">@@Html.Raw()</code> kullanıldığı için girdiğiniz script kodu tarayıcıda çalışır.</p>
<hr />

<form action="/Xss/ReflectedVulnerable" method="get" class="mb-4">
    <div class="input-group w-50">
        <input type="text" name="searchKeyword" class="form-control" placeholder="Sitede ara..." />
        <button type="submit" class="btn btn-danger">Ara</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(ViewBag.Keyword))
{
    <div class="alert alert-danger">
        <!-- ZAFİYET BURADA -->
        Aranan Kelime: <strong>@Html.Raw(ViewBag.Keyword)</strong> 
    </div>
}

<div class="mt-4 p-3 bg-light border">
    <strong>Test Payload:</strong><br> 
    <code>&lt;script&gt;alert('XSS Çalıştı!')&lt;/script&gt;</code>
</div>