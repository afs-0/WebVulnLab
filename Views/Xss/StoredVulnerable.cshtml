@model List<string>
@{ ViewData["Title"] = "Zafiyetli Stored XSS"; }

<h3 class="text-danger">Stored XSS - Zafiyetli</h3>
<p class="text-muted">Burada <code class="text-danger">@@Html.Raw()</code> kullanıldığı için girdiğiniz script kodu encode edilmeden kaydedilir.</p>
<hr />

<form action="/Xss/StoredVulnerable" method="post" class="mb-4">
    <textarea name="newComment" class="form-control w-50 mb-2" rows="2" placeholder="Yorum ekle..."></textarea>
    <button type="submit" class="btn btn-danger">Yorum Ekle</button>
</form>

<ul class="list-group w-50">
    @foreach (var comment in Model)
    {
        <!-- ZAFİYET BURADA -->
        <li class="list-group-item">@Html.Raw(comment)</li>
    }
</ul>

<div class="mt-4 p-3 bg-light border">
    <strong>Test Payload:</strong><br>
    <code>&lt;img src="x" onerror="alert('Kalıcı XSS!')"&gt;</code>
</div>
