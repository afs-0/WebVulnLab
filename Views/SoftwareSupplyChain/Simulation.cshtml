@{
    ViewData["Title"] = "Tedarik Zinciri Simülasyonu";
    var stolenLogs = ViewBag.StolenLogs as List<string>;
}

<div class="container-fluid mt-4">
    <div class="mb-4">
        <h4>Saldırı Zinciri (Nasıl Çalışıyor?)</h4>
        <ol class="text-muted">
            <li><strong>1. Adım:</strong> Sol taraftaki alana hassas kullanıcı verilerinizi yapıştırın (Örn: <code>admin,admin@site.com,Password123!</code>).</li>
            <li><strong>2. Adım:</strong> "Verileri İçe Aktar" butonuna tıklayın. Uygulama "Başarıyla aktarıldı" diyerek sahte bir güvenlik hissi yaratacaktır.</li>
            <li><strong>3. Adım:</strong> Sağ taraftaki saldırgan paneline bakın. Uygulama düzgün çalışmasına rağmen, kullandığınız kütüphane içindeki mantık veriyi gizlice çaldı!</li>
        </ol>
    </div>

    <div class="row">
        <!-- SOL TARAF: Kullanıcı/Geliştirici Ekranı -->
        <div class="col-md-6">
            <div class="card border-primary shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">🏢 Şirket Paneli: Kullanıcı İçe Aktarma</h5>
                </div>
                <div class="card-body bg-light">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success border-success font-weight-bold shadow-sm">
                            ✅ @TempData["Success"]
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <form action="/A03/Simulation" method="post">
                        <div class="mb-3">
                            <label for="csvPayload" class="form-label font-weight-bold">CSV Verisini Buraya Yapıştırın:</label>
                            <textarea class="form-control font-monospace" id="csvPayload" name="csvPayload" rows="8" placeholder="KullanıcıAdı,Email,Şifre&#10;admin,admin@sirket.com,GizliSifre123&#10;ceo,ceo@sirket.com,Patron2025"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 fw-bold">
                            Verileri İçe Aktar (3. Taraf Kütüphaneyi Kullan)
                        </button>
                    </form>
                    <div class="mt-3 text-muted" style="font-size: 0.85em;">
                        <i class="bi bi-info-circle"></i> Sistem, veri ayrıştırma işlemi için "SuperCsvParser v2.1" açık kaynak kütüphanesini kullanmaktadır.
                    </div>
                </div>
            </div>
        </div>

        <!-- SAĞ TARAF: Saldırganın Terminal Ekranı -->
        <div class="col-md-6">
            <div class="card border-danger shadow-sm h-100">
                <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">🥷 Saldırgan C2 Sunucusu (Terminal)</h5>
                    <span class="badge bg-dark text-danger border border-danger">Canlı Bağlantı: Açık</span>
                </div>
                <div class="card-body p-0" style="background-color: #0c0c0c;">
                    <div style="font-family: 'Courier New', Courier, monospace; font-size: 14px; color: #ff3333; height: 350px; overflow-y: auto; padding: 15px;">
                        <div>[SİSTEM] Komuta ve Kontrol (C2) Sunucusu başlatıldı...</div>
                        <div>[SİSTEM] Kurban hedeflerden (Trojan kütüphanelerden) veri bekleniyor...</div>
                        <br />

                        @if (stolenLogs != null && stolenLogs.Any())
                        {
                            foreach (var log in stolenLogs)
                            {
                                <div class="mb-2">
                                    <span style="color: #00ff00;">@log.Split('\n')[0]</span><br />
                                    <span style="color: #ffcccc; margin-left: 10px;">@Html.Raw(log.Split('\n')[1].Replace("\n", "<br/>"))</span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-muted" style="color: #666 !important;">
                                Henüz ele geçirilen bir veri yok. Sol taraftaki hedefin formu kullanması bekleniyor...
                            </div>
                        }
                        
                        <!-- Terminalde yanıp sönen imleç -->
                        <div class="mt-2" style="color: #ff3333;">C:\Attacker> <span style="animation: blinker 1s linear infinite;">_</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Yanıp sönen terminal imleci için küçük bir CSS animasyonu */
    @@keyframes blinker {
        50% { opacity: 0; }
    }
</style>