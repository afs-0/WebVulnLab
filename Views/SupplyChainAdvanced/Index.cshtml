@{
    ViewData["Title"] = "Gerçekçi Tedarik Zinciri Saldırısı";
    Layout = null; 
    
    // Hangi sekmenin aktif olacağını belirliyoruz (Varsayılan: Müşteri)
    string activeTab = TempData["ActiveTab"] as string ?? "customer";
}

<!DOCTYPE html>
<html>
<head>
    <title>A03 - Tedarik Zinciri</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background-color: #e9ecef; }
        .browser-window { background: white; border-radius: 10px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); overflow: hidden; margin-top: 20px; }
        .browser-header { background: #dee2e6; padding: 10px 10px 0 10px; display: flex; align-items: flex-end; border-bottom: 1px solid #ccc; }
        .browser-dots { display: flex; gap: 6px; padding-bottom: 12px; padding-left: 5px; margin-right: 15px; }
        .dot { width: 12px; height: 12px; border-radius: 50%; }
        .dot-red { background-color: #ff5f56; }
        .dot-yellow { background-color: #ffbd2e; }
        .dot-green { background-color: #27c93f; }
        
        /* Tarayıcı Sekmeleri (Tabs) Tasarımı */
        .nav-tabs { border-bottom: none; }
        .nav-tabs .nav-link { border: 1px solid transparent; border-top-left-radius: 8px; border-top-right-radius: 8px; color: #495057; background-color: #e9ecef; margin-right: 2px; padding: 8px 15px; font-weight: 500; }
        .nav-tabs .nav-link:hover { background-color: #f8f9fa; border-color: #e9ecef #e9ecef #dee2e6; }
        .nav-tabs .nav-link.active { color: #000; background-color: #fff; border-color: #ccc #ccc #fff; border-bottom-color: transparent !important; margin-bottom: -1px; }
        
        .tab-content { padding: 30px; min-height: 400px; }
        .terminal { background-color: #1e1e1e; color: #00ff00; font-family: 'Courier New', monospace; font-size: 14px; height: 300px; overflow-y: auto; padding: 15px; border-radius: 5px; }
        .terminal-red { color: #ff3333; }
    </style>
</head>
<body>
    <div class="container py-4">
        
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h3 class="mb-0">A03: Yazılım Tedarik Zinciri Hataları</h3>
                <small class="text-muted">Farklı sekmeler arasında gezinerek senaryoyu oynayın.</small>
            </div>
            <form action="/A03/Reset" method="post">
                <button class="btn btn-danger btn-sm shadow-sm">🔄 Tüm Sistemi Sıfırla</button>
            </form>
        </div>

        <div class="browser-window">
            <!-- Sahte Tarayıcı Başlığı ve Sekmeler -->
            <div class="browser-header">
                <div class="browser-dots">
                    <div class="dot dot-red"></div>
                    <div class="dot dot-yellow"></div>
                    <div class="dot dot-green"></div>
                </div>
                
                <ul class="nav nav-tabs" id="scenarioTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-customer" data-bs-toggle="tab" data-bs-target="#customer" type="button" role="tab">
                            🛒 Müşteri Ekranı
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-it-team" data-bs-toggle="tab" data-bs-target="#it-team" type="button" role="tab">
                            💻 IT Ekibi (DevOps)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-logs" data-bs-toggle="tab" data-bs-target="#logs" type="button" role="tab">
                            🗄️ Şirket Sunucusu
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link text-danger fw-bold" id="tab-hacker" data-bs-toggle="tab" data-bs-target="#hacker" type="button" role="tab">
                            🥷 Hacker C2 Paneli
                        </button>
                    </li>
                </ul>
            </div>

            <!-- Sekme İçerikleri -->
            <div class="tab-content" id="scenarioTabsContent">
                
                <!-- SEKME 1: MÜŞTERİ -->
                <div class="tab-pane fade" id="customer" role="tabpanel">
                    <div class="row justify-content-center">
                        <div class="col-md-6">
                            <h4 class="mb-4 text-center">E-Ticaret Ödeme Sayfası</h4>
                            @if (TempData["PaymentMsg"] != null)
                            {
                                <div class="alert alert-success fw-bold text-center shadow-sm">✅ @TempData["PaymentMsg"]</div>
                            }
                            <div class="card shadow-sm border-0 bg-light">
                                <div class="card-body p-4">
                                    <form action="/A03/Checkout" method="post">
                                        <div class="mb-3">
                                            <label class="form-label text-muted small fw-bold">Kart Üzerindeki İsim</label>
                                            <input type="text" name="cardHolder" class="form-control" value="Ahmet Yılmaz" required />
                                        </div>
                                        <div class="row mb-4">
                                            <div class="col-8">
                                                <label class="form-label text-muted small fw-bold">Kart Numarası</label>
                                                <input type="text" name="cardNumber" class="form-control" value="4544 1234 5678 9012" required />
                                            </div>
                                            <div class="col-4">
                                                <label class="form-label text-muted small fw-bold">CVV</label>
                                                <input type="text" name="cvv" class="form-control" value="123" required />
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-primary w-100 fs-5 py-2">Ödemeyi Tamamla 💳</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SEKME 2: IT EKİBİ -->
                <div class="tab-pane fade" id="it-team" role="tabpanel">
                    <div class="row justify-content-center">
                        <div class="col-md-8">
                            <h4 class="mb-4"><i class="bi bi-box-seam"></i> Paket Yöneticisi (NuGet)</h4>
                            <div class="card border-secondary shadow-sm">
                                <div class="card-body">
                                    <p>Projede kullanılan Ödeme Kütüphanesi: <strong>FastPay.SDK</strong></p>
                                    <p class="fs-5">Mevcut Sürüm: <span class="badge @(ViewBag.CurrentVersion == "1.0.0" ? "bg-success" : "bg-danger")">v@(ViewBag.CurrentVersion)</span></p>
                                    
                                    <hr />

                                    @if (ViewBag.CurrentVersion == "1.0.0")
                                    {
                                        <div class="alert alert-info">
                                            <strong>ℹ️ Güncelleme Mevcut: v1.1.0</strong><br />
                                            Sürüm Notları: Performans iyileştirmeleri ve küçük hata düzeltmeleri yapıldı.
                                        </div>
                                        <form action="/A03/UpdateDependency" method="post">
                                            <button type="submit" class="btn btn-warning fw-bold px-4 py-2">
                                                <i class="bi bi-cloud-arrow-down-fill"></i> Bağımlılığı Güncelle (Update Package)
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <div class="alert alert-danger border-danger">
                                            <h5 class="alert-heading">⚠️ TRUVA ATI YÜKLENDİ!</h5>
                                            <p class="mb-0">Açık kaynak kütüphaneyi <strong>v1.1.0</strong> sürümüne güncellediniz. Ancak bu sürümün GitHub deposu bir saldırgan tarafından ele geçirilmişti. Şu an sisteminizde gizli bir <em>arka kapı (backdoor)</em> kodu çalışıyor. Ödemeler normal çalışmaya devam ettiği için testlerde hiçbir sorun çıkmadı.</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SEKME 3: SİSTEM LOGLARI -->
                <div class="tab-pane fade" id="logs" role="tabpanel">
                    <h4><i class="bi bi-server"></i> Şirket Sunucusu İşlem Kayıtları</h4>
                    <p class="text-muted">Buradaki loglar, şirketinizin kendi sunucusunda gördüğü tamamen yasal ve normal kayıtlardır.</p>
                    <div class="terminal shadow">
                        @if (((List<string>)ViewBag.SystemLogs).Count == 0)
                        {
                            <span class="text-secondary">[SİSTEM] Beklemede. Henüz bir işlem yapılmadı...</span>
                        }
                        @foreach (var log in ViewBag.SystemLogs)
                        {
                            <div>> @log</div>
                        }
                    </div>
                </div>

                <!-- SEKME 4: HACKER C2 -->
                <div class="tab-pane fade" id="hacker" role="tabpanel">
                    <h4 class="text-danger"><i class="bi bi-bug-fill"></i> Saldırgan C2 Sunucusu (Dark Web)</h4>
                    <p class="text-muted">Açık kaynak FastPay.SDK kütüphanesine gizlenen kod, ele geçirdiği verileri sessizce bu ekrana yollar.</p>
                    <div class="terminal terminal-red shadow">
                        <div>[HACKER KONSOLU] FastPay.SDK v1.1.0 ağlarına bağlanan kurbanlar dinleniyor...</div>
                        <div class="mb-3">========================================================</div>
                        
                        @if (((List<string>)ViewBag.AttackerLogs).Count == 0)
                        {
                            <span style="color: #666;">Veri yok. Kütüphane henüz güncellenmedi veya güncel kütüphane ile ödeme yapılmadı.</span>
                        }
                        @foreach (var log in ViewBag.AttackerLogs)
                        {
                            <div class="fw-bold">> @log</div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Bootstrap JS ve Aktif Sekme Mantığı -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Sunucudan gelen TempData["ActiveTab"] bilgisine göre ilgili sekmeyi aç
            var activeTabId = "tab-@activeTab";
            var triggerEl = document.getElementById(activeTabId);
            if(triggerEl) {
                var tab = new bootstrap.Tab(triggerEl);
                tab.show();
            }
        });
    </script>
</body>
</html>